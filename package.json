{
  "name": "fg-sparky-bot",
  "description": "Source code for the FG sparky bot, inspired by the GD discord sparky bot",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "version": "1.3.7",
  "scripts": {
    "dev": "deno run --watch --allow-env --allow-read=.,/etc/alpine-release,/usr/bin/ldd --allow-write=.,fg-sparky-bot.log --allow-ffi=node_modules --allow-sys --allow-net=gateway.discord.gg,*.discord.gg,discord.com --allow-run=/bin/sh src/main.ts",
    "build": "deno run -E --allow-ffi=node_modules --allow-read=.,/usr/bin/ldd --allow-write=. npm:rolldown -c rolldown.config.ts",
    "lint": "oxlint . --type-check --type-aware --ignore-path=.gitignore",
    "lint:fix": "oxlint --type-check --type-aware --fix --fix-suggestions . --ignore-path=.gitignore",
    "fmt": "dprint fmt",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "imports": {
    "#stores": "./src/stores.ts",
    "#stores-types": "./src/stores/index.ts",
    "#db": "./src/db/index.ts",
    "#utils/*": "./src/utils/*",
    "#numberdex/*": "./src/numberdex/*",
    "#fg-sparky/*": "./src/sparky/*",
    "#cmd-loader": "./src/cmd-handler/loader.ts",
    "#cmds": "./src/cmds.ts"
  },
  "dependencies": {
    "@sapphire/discord.js-utilities": "catalog:discord",
    "@sapphire/result": "catalog:utils",
    "libsql": "catalog:db",
    "bufferutil": "catalog:discord",
    "chalk": "catalog:utils",
    "commander": "catalog:utils",
    "cronbake": "catalog:utils",
    "discord.js": "catalog:discord",
    "reflect-metadata": "catalog:db",
    "typeorm": "catalog:db",
    "winston": "catalog:utils",
    "zod": "catalog:types"
  },
  "devDependencies": {
    "rolldown": "catalog:utils",
    "@types/deno": "catalog:types",
    "@types/node": "catalog:types",
    "@typescript/native-preview": "catalog:types",
    "dprint": "catalog:linting",
    "oxlint": "catalog:linting",
    "oxlint-tsgolint": "catalog:linting"
  },
  "workspaces": {
    "catalogs": {
      "db": {
        "reflect-metadata": "^0.2.2",
        "libsql": "^0.5.29",
        "typeorm": "^1.0.0"
      },
      "discord": {
        "@sapphire/discord.js-utilities": "^7.3.3",
        "bufferutil": "^4.1.0",
        "discord.js": "^14.26.0"
      },
      "linting": {
        "dprint": "^0.54.0",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.23.0"
      },
      "types": {
        "@types/deno": "^2.7.0",
        "@types/node": "^25.5.0",
        "@typescript/native-preview": "7.0.0-dev.20260525.1",
        "zod": "^4.3.6"
      },
      "utils": {
        "@sapphire/result": "^2.8.0",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "cronbake": "^0.4.0",
        "winston": "^3.19.0",
        "rolldown": "^1.0.2"
      }
    }
  }
}
